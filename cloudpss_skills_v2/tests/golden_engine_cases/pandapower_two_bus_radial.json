      "pv_curve": [
        {"scale": 1.0, "bus": "Load", "voltage": 1.011301},
        {"scale": 2.0, "bus": "Load", "voltage": 1.002201},
        {"scale": 4.0, "bus": "Load", "voltage": 0.982673},
        {"scale": 8.0, "bus": "Load", "voltage": 0.937069}
