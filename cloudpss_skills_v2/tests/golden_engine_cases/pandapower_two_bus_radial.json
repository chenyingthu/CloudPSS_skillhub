{
  "case_id": "pandapower_two_bus_radial",
  "description": "Two-bus radial pandapower benchmark with one external grid, one line, and one load.",
  "capability": {
    "skill_runnable": true,
    "engine_runnable": true,
    "engine": "pandapower",
    "engine_claim": "pandapower_powerflow_short_circuit_and_voltage_stability",
    "engine_notes": "The tests load this repository JSON artifact through the pandapower adapter, run power-flow and IEC 60909 short-circuit adapters, run the short_circuit skill, and run the voltage_stability skill over explicit load-scaling levels."
  },
  "model": {
    "format": "pandapower_network_spec_v1",
    "sn_mva": 100.0,
    "buses": [
      {"id": "source", "name": "Source", "vn_kv": 110.0},
      {"id": "load", "name": "Load", "vn_kv": 110.0}
    ],
    "external_grids": [
      {
        "bus": "source",
        "name": "Grid",
        "vm_pu": 1.02,
        "va_degree": 0.0,
        "s_sc_max_mva": 2000.0,
        "s_sc_min_mva": 1500.0,
        "rx_max": 0.1,
        "rx_min": 0.1
      }
    ],
    "lines": [
      {
        "from_bus": "source",
        "to_bus": "load",
        "name": "Line",
        "length_km": 10.0,
        "r_ohm_per_km": 0.05,
        "x_ohm_per_km": 0.4,
        "c_nf_per_km": 0.0,
        "max_i_ka": 1.0
      }
    ],
    "loads": [
      {"bus": "load", "name": "Load", "p_mw": 50.0, "q_mvar": 20.0}
    ]
  },
  "power_flow_config": {
    "model_id": "pandapower_two_bus_radial",
    "algorithm": "newton_raphson",
    "tolerance": 1e-8,
    "max_iterations": 20
  },
  "short_circuit_config": {
    "model_id": "pandapower_two_bus_radial",
    "fault_type": "3ph"
  },
  "skill_configs": {
    "short_circuit": {
      "skill": "short_circuit",
      "engine": "pandapower",
      "model": {
        "rid": "pandapower_two_bus_radial",
        "source": "local"
      },
      "fault": {
        "location": "Load",
        "type": "3ph",
        "resistance": 0.0
      },
      "calculation": {
        "base_voltage": 110.0,
        "base_capacity": 100.0
      },
      "output": {
        "format": "json",
        "prefix": "pandapower_two_bus_short_circuit",
        "generate_report": false
      }
    },
    "voltage_stability": {
      "skill": "voltage_stability",
      "engine": "pandapower",
      "model": {
        "rid": "pandapower_two_bus_radial",
        "source": "local"
      },
      "scan": {
        "load_scaling": [1.0, 2.0, 4.0, 8.0],
        "scale_generation": false
      },
      "monitoring": {
        "buses": ["Load"],
        "collapse_threshold": 0.95
      },
      "output": {
        "format": "json",
        "prefix": "pandapower_two_bus_voltage_stability",
        "generate_report": false,
        "export_pv_curve": false
      }
    }
  },
  "expected": {
    "power_flow": {
      "converged": true,
      "bus_count": 2,
      "branch_count": 1,
      "source_bus_voltage_pu": 1.02,
