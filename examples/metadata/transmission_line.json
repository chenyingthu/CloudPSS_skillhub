{
  "component_id": "model/CloudPSS/TransmissionLine",
  "name": "三相交流传输线",
  "description": "三相交流传输线模型，支持集中参数和分布参数，适用于潮流计算和电磁暂态仿真",
  "version": "1.0.0",
  "category": "transmission",
  "source": {
    "documentation_url": "https://kb.cloudpss.net/documents/software/emtlab/component-library/",
    "version": "2024.12"
  },
  "parameters": {
    "groups": [
      {
        "group_id": "basic",
        "name": "基础参数",
        "description": "线路基本电气参数",
        "parameters": [
          {
            "key": "R",
            "display_name": "单位长度电阻",
            "type": "real",
            "unit": "Ω/km",
            "description": "线路单位长度正序电阻",
            "required": true,
            "default": 0.02,
            "constraints": {"min": 0.0}
          },
          {
            "key": "X",
            "display_name": "单位长度电抗",
            "type": "real",
            "unit": "Ω/km",
            "description": "线路单位长度正序电抗",
            "required": true,
            "default": 0.4,
            "constraints": {"min": 0.0}
          },
          {
            "key": "B",
            "display_name": "单位长度电纳",
            "type": "real",
            "unit": "μS/km",
            "description": "线路单位长度正序电纳",
            "required": false,
            "default": 2.8
          },
          {
            "key": "Length",
            "display_name": "线路长度",
            "type": "real",
            "unit": "km",
            "description": "线路总长度",
            "required": true,
            "default": 100.0,
            "constraints": {"min": 0.001}
          }
        ]
      },
      {
        "group_id": "rated",
        "name": "额定参数",
        "description": "线路额定运行参数",
        "parameters": [
          {
            "key": "Vnom",
            "display_name": "额定电压",
            "type": "real",
            "unit": "kV",
            "description": "线路额定电压（线电压有效值）",
            "required": true,
            "default": 220.0
          },
          {
            "key": "Snom",
            "display_name": "额定容量",
            "type": "real",
            "unit": "MVA",
            "description": "线路额定传输容量",
            "required": false,
            "default": 100.0
          }
        ]
      }
    ]
  },
  "pins": {
    "electrical": [
      {
        "key": "1",
        "name": "首端",
        "type": "electrical",
        "dimension": "3×1",
        "description": "线路首端三相连接端口",
        "required": true
      },
      {
        "key": "2",
        "name": "末端",
        "type": "electrical",
        "dimension": "3×1",
        "description": "线路末端三相连接端口",
        "required": true
      }
    ]
  },
  "validation_rules": {
    "require_both_ends": true
  },
  "simulation_support": {
    "powerflow": true,
    "emt": true,
    "phasor": true
  }
}
