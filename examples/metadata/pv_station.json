{
  "component_id": "model/CloudPSS/PVStation",
  "name": "光伏电站模型",
  "description": "光伏电站等值模型，支持集中式逆变器和组串式逆变器配置，用于电磁暂态仿真",
  "version": "1.0.0",
  "category": "renewable",
  "source": {
    "documentation_url": "https://kb.cloudpss.net/documents/software/emtlab/component-library/renewable-energy-modules/",
    "version": "2024.12"
  },
  "parameters": {
    "groups": [
      {
        "group_id": "basic",
        "name": "基础参数",
        "description": "光伏电站基本配置参数",
        "parameters": [
          {
            "key": "Vbase",
            "display_name": "基准电压",
            "type": "real",
            "unit": "kV",
            "description": "光伏阵列额定电压",
            "required": true,
            "default": 0.315
          },
          {
            "key": "Fnom",
            "display_name": "额定频率",
            "type": "real",
            "unit": "Hz",
            "description": "系统额定频率",
            "required": true,
            "default": 50.0
          },
          {
            "key": "Pnom",
            "display_name": "额定功率",
            "type": "real",
            "unit": "MW",
            "description": "光伏电站总额定装机容量",
            "required": true,
            "default": 50.0
          }
        ]
      },
      {
        "group_id": "pv_array",
        "name": "光伏阵列参数",
        "description": "光伏阵列特性参数",
        "parameters": [
          {
            "key": "Irradiance",
            "display_name": "光照强度",
            "type": "real",
            "unit": "W/m²",
            "description": "标准光照强度",
            "required": false,
            "default": 1000.0,
            "constraints": {"min": 0, "max": 1500}
          },
          {
            "key": "Temperature",
            "display_name": "环境温度",
            "type": "real",
            "unit": "°C",
            "description": "光伏板温度",
            "required": false,
            "default": 25.0
          },
          {
            "key": "Efficiency",
            "display_name": "转换效率",
            "type": "real",
            "unit": "pu",
            "description": "光电转换效率",
            "required": false,
            "default": 0.18,
            "constraints": {"min": 0.05, "max": 0.3}
          }
        ]
      },
      {
        "group_id": "control",
        "name": "控制参数",
        "description": "逆变器控制参数",
        "parameters": [
          {
            "key": "MPPTEnable",
            "display_name": "MPPT使能",
            "type": "boolean",
            "description": "是否启用最大功率点跟踪",
            "required": false,
            "default": true
          },
          {
            "key": "VdcRef",
            "display_name": "直流电压参考值",
            "type": "real",
            "unit": "V",
            "description": "直流侧电压参考值",
            "required": false,
            "default": 800.0
          },
          {
            "key": "PFMode",
            "display_name": "功率因数控制模式",
            "type": "choice",
            "description": "功率因数控制模式",
            "required": false,
            "default": "constant_pf",
            "choices": ["constant_pf", "constant_q", "constant_v"]
          }
        ]
      }
    ]
  },
  "pins": {
    "electrical": [
      {
        "key": "0",
        "name": "电气连接",
        "type": "electrical",
        "dimension": "3×1",
        "description": "光伏电站三相电气连接端口",
        "required": true
      }
    ],
    "input": [
      {
        "key": "Pcmd",
        "name": "有功功率指令",
        "type": "input",
        "dimension": "1×1",
        "description": "有功功率控制指令",
        "required": false
      }
    ],
    "output": [
      {
        "key": "Pout",
        "name": "输出功率",
        "type": "output",
        "dimension": "1×1",
        "description": "总有功功率输出",
        "required": false
      }
    ]
  },
  "validation_rules": {
    "require_at_least_one_pin": true
  },
  "simulation_support": {
    "emt": true,
    "powerflow": true
  }
}
