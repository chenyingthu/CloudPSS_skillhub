{
  "component_id": "model/CloudPSS/_newGenerator",
  "name": "同步发电机",
  "description": "同步发电机模型，支持经典模型和详细模型，适用于潮流计算和电磁暂态仿真",
  "version": "1.0.0",
  "category": "generator",
  "source": {
    "documentation_url": "https://kb.cloudpss.net/documents/software/emtlab/component-library/",
    "version": "2024.12"
  },
  "parameters": {
    "groups": [
      {
        "group_id": "basic",
        "name": "基础参数",
        "description": "发电机基本额定参数",
        "parameters": [
          {
            "key": "Snom",
            "display_name": "额定容量",
            "type": "real",
            "unit": "MVA",
            "description": "发电机额定视在功率",
            "required": true,
            "default": 100.0
          },
          {
            "key": "Vnom",
            "display_name": "额定电压",
            "type": "real",
            "unit": "kV",
            "description": "发电机额定线电压",
            "required": true,
            "default": 10.5
          },
          {
            "key": "Fnom",
            "display_name": "额定频率",
            "type": "real",
            "unit": "Hz",
            "description": "系统额定频率",
            "required": false,
            "default": 50.0
          }
        ]
      },
      {
        "group_id": "powerflow",
        "name": "潮流计算参数",
        "description": "潮流计算初始运行点参数",
        "parameters": [
          {
            "key": "P0",
            "display_name": "初始有功功率",
            "type": "real",
            "unit": "MW",
            "description": "发电机初始有功功率输出",
            "required": false,
            "default": 80.0
          },
          {
            "key": "Q0",
            "display_name": "初始无功功率",
            "type": "real",
            "unit": "Mvar",
            "description": "发电机初始无功功率输出",
            "required": false,
            "default": 10.0
          },
          {
            "key": "V0",
            "display_name": "初始电压设定值",
            "type": "real",
            "unit": "pu",
            "description": "机端电压设定值（标幺值）",
            "required": false,
            "default": 1.0
          }
        ]
      }
    ]
  },
  "pins": {
    "electrical": [
      {
        "key": "0",
        "name": "发电机端",
        "type": "electrical",
        "dimension": "3×1",
        "description": "发电机三相输出端口",
        "required": true
      }
    ]
  },
  "validation_rules": {
    "require_at_least_one_pin": true
  },
  "simulation_support": {
    "powerflow": true,
    "emt": true
  }
}
