{
  "component_id": "model/CloudPSS/_newLoad_3p",
  "name": "三相负荷",
  "description": "三相交流负荷模型，支持恒功率、恒电流和恒阻抗负荷类型，适用于潮流计算和电磁暂态仿真",
  "version": "1.0.0",
  "category": "load",
  "source": {
    "documentation_url": "https://kb.cloudpss.net/documents/software/emtlab/component-library/",
    "version": "2024.12"
  },
  "parameters": {
    "groups": [
      {
        "group_id": "basic",
        "name": "基础参数",
        "description": "负荷基本电气参数",
        "parameters": [
          {
            "key": "Vnom",
            "display_name": "额定电压",
            "type": "real",
            "unit": "kV",
            "description": "负荷额定电压",
            "required": true,
            "default": 10.5
          },
          {
            "key": "Fnom",
            "display_name": "额定频率",
            "type": "real",
            "unit": "Hz",
            "description": "系统额定频率",
            "required": false,
            "default": 50.0
          }
        ]
      },
      {
        "group_id": "power",
        "name": "功率参数",
        "description": "负荷功率设定",
        "parameters": [
          {
            "key": "P0",
            "display_name": "有功功率",
            "type": "real",
            "unit": "MW",
            "description": "负荷有功功率（三相总功率）",
            "required": true,
            "default": 50.0
          },
          {
            "key": "Q0",
            "display_name": "无功功率",
            "type": "real",
            "unit": "Mvar",
            "description": "负荷无功功率（三相总功率）",
            "required": true,
            "default": 20.0
          },
          {
            "key": "LoadModel",
            "display_name": "负荷模型类型",
            "type": "choice",
            "description": "负荷模型类型",
            "required": false,
            "default": "constant_pq",
            "choices": ["constant_pq", "constant_z", "constant_i", "zip"]
          }
        ]
      }
    ]
  },
  "pins": {
    "electrical": [
      {
        "key": "0",
        "name": "负荷连接",
        "type": "electrical",
        "dimension": "3×1",
        "description": "负荷三相连接端口",
        "required": true
      }
    ]
  },
  "validation_rules": {},
  "simulation_support": {
    "powerflow": true,
    "emt": true,
    "phasor": true
  }
}
